    {
        "dashboard": {
            "title": "Laravel API - Monitoring Complet",
            "tags": [
                "laravel",
                "api",
                "monitoring"
            ],
            "timezone": "browser",
            "schemaVersion": 38,
            "version": 1,
            "refresh": "10s",
            "time": {
                "from": "now-6h",
                "to": "now"
            },
            "panels": [
                {
                    "id": 1,
                    "title": "Nombre d'Utilisateurs",
                    "type": "stat",
                    "gridPos": {
                        "h": 6,
                        "w": 6,
                        "x": 0,
                        "y": 0
                    },
                    "targets": [
                        {
                            "expr": "laravel_users_total",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "blue",
                                        "value": null
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 2,
                    "title": "Nombre de Produits",
                    "type": "stat",
                    "gridPos": {
                        "h": 6,
                        "w": 6,
                        "x": 6,
                        "y": 0
                    },
                    "targets": [
                        {
                            "expr": "laravel_products_total",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 3,
                    "title": "Produits en Rupture",
                    "type": "stat",
                    "gridPos": {
                        "h": 6,
                        "w": 6,
                        "x": 12,
                        "y": 0
                    },
                    "targets": [
                        {
                            "expr": "laravel_products_out_of_stock",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    },
                                    {
                                        "color": "orange",
                                        "value": 5
                                    },
                                    {
                                        "color": "red",
                                        "value": 10
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 4,
                    "title": "Valeur du Stock",
                    "type": "stat",
                    "gridPos": {
                        "h": 6,
                        "w": 6,
                        "x": 18,
                        "y": 0
                    },
                    "targets": [
                        {
                            "expr": "laravel_stock_value_total",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "currencyEUR",
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "purple",
                                        "value": null
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 5,
                    "title": "CPU Usage",
                    "type": "gauge",
                    "gridPos": {
                        "h": 8,
                        "w": 8,
                        "x": 0,
                        "y": 6
                    },
                    "targets": [
                        {
                            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "showThresholdLabels": true,
                        "showThresholdMarkers": true,
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "percent",
                            "min": 0,
                            "max": 100,
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    },
                                    {
                                        "color": "yellow",
                                        "value": 70
                                    },
                                    {
                                        "color": "red",
                                        "value": 85
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 6,
                    "title": "RAM Usage",
                    "type": "gauge",
                    "gridPos": {
                        "h": 8,
                        "w": 8,
                        "x": 8,
                        "y": 6
                    },
                    "targets": [
                        {
                            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "showThresholdLabels": true,
                        "showThresholdMarkers": true,
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "percent",
                            "min": 0,
                            "max": 100,
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    },
                                    {
                                        "color": "yellow",
                                        "value": 80
                                    },
                                    {
                                        "color": "red",
                                        "value": 90
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 7,
                    "title": "Disk Usage",
                    "type": "gauge",
                    "gridPos": {
                        "h": 8,
                        "w": 8,
                        "x": 16,
                        "y": 6
                    },
                    "targets": [
                        {
                            "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "showThresholdLabels": true,
                        "showThresholdMarkers": true,
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "percent",
                            "min": 0,
                            "max": 100,
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    },
                                    {
                                        "color": "yellow",
                                        "value": 80
                                    },
                                    {
                                        "color": "red",
                                        "value": 90
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 8,
                    "title": "Mémoire Laravel",
                    "type": "timeseries",
                    "gridPos": {
                        "h": 8,
                        "w": 12,
                        "x": 0,
                        "y": 14
                    },
                    "targets": [
                        {
                            "expr": "laravel_memory_usage_bytes / 1024 / 1024",
                            "legendFormat": "Memory Usage (MB)",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "legend": {
                            "displayMode": "list",
                            "placement": "bottom"
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "decmbytes",
                            "color": {
                                "mode": "palette-classic"
                            }
                        }
                    }
                },
                {
                    "id": 9,
                    "title": "Nombre de Catégories",
                    "type": "stat",
                    "gridPos": {
                        "h": 8,
                        "w": 12,
                        "x": 12,
                        "y": 14
                    },
                    "targets": [
                        {
                            "expr": "laravel_categories_total",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "orange",
                                        "value": null
                                    }
                                ]
                            }
                        }
                    }
                }
            ]
        },
        "overwrite": true,
        "folderId": 0,
        "folderUid": ""
    }