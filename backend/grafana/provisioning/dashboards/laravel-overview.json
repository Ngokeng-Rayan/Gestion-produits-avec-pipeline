    {
        "dashboard": {
            "title": "Laravel API - Monitoring Complet",
            "tags": [
                "laravel",
                "api",
                "monitoring"
            ],
            "timezone": "browser",
            "schemaVersion": 38,
            "version": 1,
            "refresh": "10s",
            "time": {
                "from": "now-6h",
                "to": "now"
            },
            "panels": [
                {
                    "id": 1,
                    "title": "Nombre d'Utilisateurs",
                    "type": "stat",
                    "gridPos": {
                        "h": 6,
                        "w": 6,
                        "x": 0,
                        "y": 0
                    },
                    "targets": [
                        {
                            "expr": "laravel_users_total",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "blue",
                                        "value": null
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 2,
                    "title": "Nombre de Produits",
                    "type": "stat",
                    "gridPos": {
                        "h": 6,
                        "w": 6,
                        "x": 6,
                        "y": 0
                    },
                    "targets": [
                        {
                            "expr": "laravel_products_total",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 3,
                    "title": "Produits en Rupture",
                    "type": "stat",
                    "gridPos": {
                        "h": 6,
                        "w": 6,
                        "x": 12,
                        "y": 0
                    },
                    "targets": [
                        {
                            "expr": "laravel_products_out_of_stock",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    },
                                    {
                                        "color": "orange",
                                        "value": 5
                                    },
                                    {
                                        "color": "red",
                                        "value": 10
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 4,
                    "title": "Valeur du Stock",
                    "type": "stat",
                    "gridPos": {
                        "h": 6,
                        "w": 6,
                        "x": 18,
                        "y": 0
                    },
                    "targets": [
                        {
                            "expr": "laravel_stock_value_total",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "colorMode": "value",
                        "graphMode": "area",
                        "orientation": "auto",
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "currencyEUR",
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "purple",
                                        "value": null
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 5,
                    "title": "CPU Usage",
                    "type": "gauge",
                    "gridPos": {
                        "h": 8,
                        "w": 8,
                        "x": 0,
                        "y": 6
                    },
                    "targets": [
                        {
                            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "showThresholdLabels": true,
                        "showThresholdMarkers": true,
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "percent",
                            "min": 0,
                            "max": 100,
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    },
                                    {
                                        "color": "yellow",
                                        "value": 70
                                    },
                                    {
                                        "color": "red",
                                        "value": 85
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 6,
                    "title": "RAM Usage",
                    "type": "gauge",
                    "gridPos": {
                        "h": 8,
                        "w": 8,
                        "x": 8,
                        "y": 6
                    },
                    "targets": [
                        {
                            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "showThresholdLabels": true,
                        "showThresholdMarkers": true,
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "percent",
                            "min": 0,
                            "max": 100,
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    },
                                    {
                                        "color": "yellow",
                                        "value": 80
                                    },
                                    {
                                        "color": "red",
                                        "value": 90
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 7,
                    "title": "Disk Usage",
                    "type": "gauge",
                    "gridPos": {
                        "h": 8,
                        "w": 8,
                        "x": 16,
                        "y": 6
                    },
                    "targets": [
                        {
                            "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
                            "refId": "A"
                        }
                    ],
                    "options": {
                        "showThresholdLabels": true,
                        "showThresholdMarkers": true,
                        "reduceOptions": {
                            "values": false,
                            "calcs": [
                                "lastNotNull"
                            ]
                        }
                    },
                    "fieldConfig": {
                        "defaults": {
                            "unit": "percent",
                            "min": 0,
                            "max": 100,
                            "color": {
                                "mode": "thresholds"
                            },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    {
                                        "color": "green",
                                        "value": null
                                    },
                                    {
                                        "color": "yellow",
                                        "value": 80
                                    },
                                    {
                                        "color": "red",
                                        "value": 90
                                    }
                                ]
                            }
                        }
                    }
                },
                {
                    "id": 8,
                    "title": "Mémoire Laravel (MB)",
                    "type": "timeseries",
                    "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
                    "targets": [
                        { "expr": "laravel_memory_usage_bytes / 1024 / 1024", "legendFormat": "Utilisée (MB)", "refId": "A" },
                        { "expr": "laravel_memory_peak_bytes / 1024 / 1024", "legendFormat": "Pic (MB)", "refId": "B" }
                    ],
                    "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
                    "fieldConfig": { "defaults": { "unit": "decmbytes", "color": { "mode": "palette-classic" } } }
                },
                {
                    "id": 9,
                    "title": "Nombre de Catégories",
                    "type": "stat",
                    "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
                    "targets": [{ "expr": "laravel_categories_total", "refId": "A" }],
                    "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
                    "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] } } }
                },
                {
                    "id": 10,
                    "title": "Réseau — Trafic entrant",
                    "type": "timeseries",
                    "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
                    "targets": [
                        { "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])", "legendFormat": "{{device}} - RX", "refId": "A" }
                    ],
                    "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
                    "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } } }
                },
                {
                    "id": 11,
                    "title": "Réseau — Trafic sortant",
                    "type": "timeseries",
                    "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
                    "targets": [
                        { "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])", "legendFormat": "{{device}} - TX", "refId": "A" }
                    ],
                    "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
                    "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } } }
                },
                {
                    "id": 12,
                    "title": "Temps de réponse moyen (s)",
                    "type": "timeseries",
                    "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
                    "targets": [
                        { "expr": "laravel_response_time_avg_seconds", "legendFormat": "Avg", "refId": "A" },
                        { "expr": "laravel_response_time_max_seconds", "legendFormat": "Max", "refId": "B" }
                    ],
                    "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
                    "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" },
                        "thresholds": { "mode": "absolute", "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 0.5 },
                            { "color": "red", "value": 1 }
                        ]}
                    }}
                },
                {
                    "id": 13,
                    "title": "Taux d'erreur HTTP (%)",
                    "type": "timeseries",
                    "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
                    "targets": [
                        { "expr": "laravel_http_error_rate", "legendFormat": "Erreurs (%)", "refId": "A" },
                        { "expr": "laravel_http_errors_4xx", "legendFormat": "4xx", "refId": "B" },
                        { "expr": "laravel_http_errors_5xx", "legendFormat": "5xx", "refId": "C" }
                    ],
                    "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
                    "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" },
                        "thresholds": { "mode": "absolute", "steps": [
                            { "color": "green", "value": null },
                            { "color": "orange", "value": 1 },
                            { "color": "red", "value": 5 }
                        ]}
                    }}
                },
                {
                    "id": 14,
                    "title": "Total Requêtes HTTP",
                    "type": "stat",
                    "gridPos": { "h": 4, "w": 6, "x": 0, "y": 38 },
                    "targets": [{ "expr": "laravel_http_requests_total", "refId": "A" }],
                    "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
                    "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
                },
                {
                    "id": 15,
                    "title": "Connexions TCP actives",
                    "type": "stat",
                    "gridPos": { "h": 4, "w": 6, "x": 6, "y": 38 },
                    "targets": [{ "expr": "node_tcp_connection_states{state=\"established\"}", "refId": "A" }],
                    "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
                    "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
                        { "color": "green", "value": null }, { "color": "orange", "value": 100 }, { "color": "red", "value": 500 }
                    ]}}}
                },
                {
                    "id": 16,
                    "title": "Processus actifs",
                    "type": "stat",
                    "gridPos": { "h": 4, "w": 6, "x": 12, "y": 38 },
                    "targets": [{ "expr": "node_procs_running", "refId": "A" }],
                    "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
                    "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
                        { "color": "green", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 100 }
                    ]}}}
                },
                {
                    "id": 17,
                    "title": "Mémoire Laravel PHP",
                    "type": "stat",
                    "gridPos": { "h": 4, "w": 6, "x": 18, "y": 38 },
                    "targets": [{ "expr": "laravel_memory_usage_bytes / 1024 / 1024", "refId": "A" }],
                    "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
                    "fieldConfig": { "defaults": { "unit": "decmbytes", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
                        { "color": "green", "value": null }, { "color": "orange", "value": 64 }, { "color": "red", "value": 128 }
                    ]}}}
                }
            ]
        },
        "overwrite": true,
        "folderId": 0,
        "folderUid": ""
    }