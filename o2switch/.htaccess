Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── Sécurité : bloquer l'accès direct aux fichiers sensibles Laravel ──
    RewriteRule ^api/\.env(.*)              - [F,NC,L]
    RewriteRule ^api/composer\.(json|lock)  - [F,NC,L]
    RewriteRule ^api/artisan                - [F,NC,L]
    RewriteRule ^api/phpunit\.xml           - [F,NC,L]
    RewriteRule ^api/(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/.*)? - [F,NC,L]

    # ── API Laravel : rediriger /api/* vers api/public/index.php ──
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^api(/.*)?$ api/public/index.php [QSA,L]

    # ── Frontend React SPA : fallback vers index.html ──
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [QSA,L]
</IfModule>
